# Uygulama testnet üzerinde çalışır (Aptos + Shelby testnet, shelbynet değil)
# VITE_APTOS_NETWORK=testnet

# Aptos API anahtarı (rate limit için): https://developers.aptoslabs.com/docs/api-access
VITE_APTOS_API_KEY=

# Shelby API anahtarı (önerilir – blob okuma/yükleme daha stabil, "[İçerik yüklenemedi]" azalır):
# https://geomi.dev → API Resource → Network: Testnet → Frontend için "client key" oluştur
VITE_SHELBY_API_KEY=

# Tino feed sözleşmesini deploy eden hesabın adresi (feed sahibi).
# Sözleşme yoksa demo modunda çalışır (sadece gönderiler, beğeni/yorum zincir dışı).
VITE_TINO_FEED_OWNER=

# Tino feed modül adresi (genelde feed sahibi ile aynı)
VITE_TINO_MODULE_ADDRESS=
